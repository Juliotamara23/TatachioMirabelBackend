{
  "compilerOptions": {
    "target": "ES6",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./build/",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@tatachio/shared": ["../../packages/shared/src/index.ts"],
      "@tatachio/shared/*": ["../../packages/shared/src/*"]
    }
  },
  "include": ["src/**/*"]
}
