// Esquema de Base de Datos para el Cabildo Tatachio Mirabel
// Siguiendo los formatos del Ministerio del Interior de Colombia

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Modelo de Usuario para autenticación
model Usuario {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String
  nombre        String
  rol           Rol       @default(CAPITANA)
  activo        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relaciones
  cabildos      UsuarioCabildo[]
}

enum Rol {
  ADMINISTRADOR
  CAPITANA
}

// Modelo de Cabildo (la comunidad indigenous)
model Cabildo {
  id              String    @id @default(uuid())
  nombre          String
 	resguardo      String
  comunidad       String
  vigencia        Int       // Año del censo
  activo          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relaciones
  usuarios        UsuarioCabildo[]
  miembros        Miembro[]
  familias        Familia[]
  reportes        Reporte[]
}

// Tabla de relación Usuario-Cabildo (muchos a muchos)
model UsuarioCabildo {
  usuarioId   String
  cabildoId   String
  rolEnCabildo String @default("CAPITANA") // Rol específico en el cabildo

  usuario     Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  cabildo     Cabildo   @relation(fields: [cabildoId], references: [id], onDelete: Cascade)

  @@id([usuarioId, cabildoId])
}

// Modelo de Familia
model Familia {
  id            String    @id @default(uuid())
  numero        Int       // Número de familia según el censo
  direccion     String?
  telefono      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relaciones
  cabildo       Cabildo   @relation(fields: [cabildoId], references: [id])
  cabildoId     String
  miembros      Miembro[]
}

model Miembro {
  id                String    @id @default(uuid())
  
  // Campos del censo (formato Ministerio del Interior)
  tipoIdentificacion TipoIdentificacion
  numeroDocumento    String    // Sin puntos ni espacios
  nombres           String    // MAYÚSCULAS
  apellidos         String    // MAYÚSCULAS
  fechaNacimiento   String    // Formato DD/MM/YYYY
  parentesco        Parentesco
  sexo              Sexo
  estadoCivil       EstadoCivil?
  profesion         String?   // MAYÚSCULAS
  escolaridad       Escolaridad?
  integrantes       Int       // Posición en la familia
  direccion         String?   // MAYÚSCULAS
  telefono          String?   // Solo números
  
  // Metadatos
  novedad           String?
  activo            Boolean   @default(true)
  estado            EstadoMiembro @default(ACTIVO)
  fechaAlta         DateTime  @default(now())
  fechaBaja         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relaciones
  familia           Familia   @relation(fields: [familiaId], references: [id])
  familiaId         String
  cabildo           Cabildo   @relation(fields: [cabildoId], references: [id])
  cabildoId         String
  reporteAltas      Reporte[] @relation("ReporteAltas")
  reporteBajas      Reporte[] @relation("ReporteBajas")

  // Índices para búsquedas frecuentes
  @@unique([numeroDocumento, cabildoId])
  @@index([familiaId])
  @@index([sexo])
}

// Enum: Tipo de identificación
enum TipoIdentificacion {
  CC  // Cédula de Ciudadanía
  TI  // Tarjeta de Identidad
  RC  // Registro Civil
  NUIP // Número Único de Identificación Personal
}

// Enum: Parentesco
enum Parentesco {
  PA  // Padre
  MA  // Madre
  CO  // Cónyuge
  HE  // Hermano
  CF  // Cabeza de Familia
  ES  // Esposo
  HI  // Hijo
  YR  // Yerno
  NU  // Nuera
  SU  // Suegro
  SO  // Sobrino
  CU  // Cuñado
  TI  // Tío
  AB  // Abuelo
  NI  // Nieto
}

// Enum: Sexo
enum Sexo {
  M   // Masculino
  F   // Femenino
}

// Enum: Estado Civil
enum EstadoCivil {
  S   // Soltero
  C   // Casado
}

// Enum: Escolaridad
enum Escolaridad {
  PR  // Primaria
  SE  // Secundaria
  UN  // Universitaria
  NI  // Ninguno
}

// Enum: Estado del miembro
enum EstadoMiembro {
  ACTIVO
  BAJA
  PENDIENTE
}

// Modelo de Reporte
model Reporte {
  id            String        @id @default(uuid())
  tipo          TipoReporte
  vigencia      Int           // Año del reporte
  estado        EstadoReporte @default(PENDIENTE)
  
  // Novedad (para altas y bajas)
  novedad       String?
  
  // Metadatos
  archivoPath   String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  // Relaciones
  cabildo      Cabildo       @relation(fields: [cabildoId], references: [id])
  cabildoId    String
  miembrosAltas Miembro[]     @relation("ReporteAltas")
  miembrosBajas Miembro[]     @relation("ReporteBajas")
}

enum TipoReporte {
  CENS0   // Censo general
  ALTAS   // Personas que ingresan al cabildo
  BAJAS   // Personas que salen del cabildo
}

enum EstadoReporte {
  PENDIENTE
  PROCESANDO
  COMPLETADO
  ERROR
}
